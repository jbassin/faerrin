{
  "name": "@faerrin/lark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-guild Discord music bot for the Faerrin campaign — joins a voice channel and streams OST tracks from a curated library, controlled via a web UI (lark.iridi.cc) and a Stream Deck REST API.",
  "scripts": {
    "dev": "vite",
    "dev:server": "bun run --hot server.ts",
    "build": "vite build",
    "start": "bun run server.ts",
    "spike": "bun run src/spike/voice-spike.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "@noble/ciphers": "^1.2.1",
    "discord.js": "^14.16.3",
    "opusscript": "^0.1.1",
    "prism-media": "^1.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8"
  }
}
