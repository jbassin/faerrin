# --- Copy to .env (gitignored, mode 0600) and fill in. Bun auto-loads .env. ---

# Discord application (lark's OWN bot — separate from @faerrin/mouth's dice bot).
# Needs the GuildVoiceStates intent enabled in the Developer Portal, and the
# bot must be invited to the campaign guild with Connect + Speak permissions.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# The single guild lark serves (D3).
LARK_GUILD_ID=

# Voice runs in a Node subprocess (Bun can't do @discordjs/voice — D1). If `node`
# isn't on the service PATH (e.g. installed via nvm), set its absolute path here.
# Find it with: which node
LARK_NODE_BIN=

# --- Phase 0 spike only: the voice channel to join for the live audio test. ---
LARK_SPIKE_CHANNEL_ID=

# --- Web server / auth (Phase 1+). ---
PORT=8788
# Secret used to sign session cookies. Generate: openssl rand -hex 32
SESSION_SECRET=
# Comma-separated Discord user IDs allowed to log in / hold API keys (D4).
LARK_ALLOWED_USER_IDS=
# Public origin, for OAuth redirect URI + cookie scoping.
LARK_PUBLIC_ORIGIN=https://lark.iridi.cc

# --- Audio (Phase 3+). ---
# Loudness normalization target in LUFS (D5/B25). Default -16.
LARK_TARGET_LUFS=-16

# Parallel downloads during a playlist import. Each item can run yt-dlp + an
# ffmpeg loudness pass, so keep this low to avoid OOM. Default 2.
LARK_INGEST_CONCURRENCY=2
# Set to 0 to skip R128 loudness measurement on ingest (saves an ffmpeg process
# per track; tracks play at unity gain until measured). Default on.
LARK_MEASURE_LOUDNESS=1
