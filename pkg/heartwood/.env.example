# Required — Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required — GitHub token. Classic PAT with `repo` scope, or a fine-grained token
# with Contents + Pull requests (read/write) on the repo that hosts content/.
GITHUB_TOKEN=ghp-...

# Required — owner/name of the GitHub repo that hosts content/
GITHUB_REPO=owner/repo

# Optional — GitHub API base URL (default https://api.github.com; set for Enterprise)
# GITHUB_API_URL=https://api.github.com

# Optional — model overrides. Defaults shown.
MODEL_SEGMENT=claude-haiku-4-5-20251001
MODEL_EXTRACT=claude-sonnet-4-6
MODEL_MATCH=claude-sonnet-4-6
MODEL_PROPOSE=claude-sonnet-4-6
MODEL_VERIFY=claude-sonnet-4-6
