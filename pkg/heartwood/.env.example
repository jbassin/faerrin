# Required — Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# The rewrite has no GitHub dependency — proposals are reviewed in the local app and
# committed via jj, not shipped as PRs.

# Optional — per-stage model overrides. Defaults shown.
MODEL_MINE=claude-sonnet-4-6
MODEL_TRIAGE=claude-haiku-4-5-20251001
MODEL_RESOLVE=claude-haiku-4-5-20251001
MODEL_SUMMARIZE=claude-sonnet-4-6
MODEL_CONFLICT=claude-sonnet-4-6
