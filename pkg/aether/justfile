list:
    just --list

# Astro dev server (HMR). Pagefind search is empty here — it indexes built HTML;
# use `just dev-search` to exercise search against a real build.
dev *args:
    bunx astro dev --port 10114 {{ args }}

# Build + preview the static site so Pagefind search works (indexes the build).
dev-search *args:
    bun run build && bunx astro preview --host --port 10114 {{ args }}

# Production build → publishes to public/ (what the reverse proxy serves).
build:
    bash build.sh

# The content pipeline + review tool live in pkg/shared-content now (the content
# platform). These are convenience wrappers that run them from there.
review:
    cd ../shared-content && bunx tsx scripts/review.ts

# Run the content pipeline. Pass a step name to run just one, e.g. `just pipeline ingest`.
pipeline *args:
    cd ../shared-content && bunx tsx scripts/run.ts {{ args }}
