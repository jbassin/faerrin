---
import { getCollection, render } from "astro:content"
import {
  slugifyFilePath,
  simplifySlug,
  resolveRelative,
  type FilePath,
  type FullSlug,
  type RelativeURL,
  type SimpleSlug,
} from "../../scripts/lib/slug.ts"
import { loadSite, listFolderChildren, folderTitle } from "../lib/site.ts"
import { folderIndexName } from "../../scripts/lib/folder-index.ts"
import PageLayout from "../layouts/PageLayout.astro"
import Breadcrumbs from "../components/Breadcrumbs.astro"
import ArticleTitle from "../components/ArticleTitle.astro"
import ContentMeta from "../components/ContentMeta.astro"
import TagList from "../components/TagList.astro"
import Backlinks from "../components/Backlinks.astro"
import SidebarImage from "../components/SidebarImage.astro"
import TableOfContents from "../components/TableOfContents.astro"
import PageList from "../components/PageList.astro"

// This catch-all owns the root namespace, so it emits BOTH content pages and
// folder listing pages (Quartz's FolderPage overwrites the content page for
// folders that have an index.md, so listings live here, not in a separate route).
// Tag pages live under tags/ (their own route). getStaticPaths must define every
// helper inline (it runs isolated).
export async function getStaticPaths() {
  const docs = await getCollection("docs")
  const relOf = (doc: (typeof docs)[number]) =>
    ((doc.filePath ?? doc.id).split("content/").at(-1) ?? "") as FilePath
  const dirname = (s: string) => {
    const i = s.lastIndexOf("/")
    return i === -1 ? "." : s.slice(0, i)
  }
  const slugs = new Map(docs.map((d) => [d, slugifyFilePath(relOf(d))]))

  // content pages: everything except non-home folder-index pages (those are
  // rendered as folder listings below).
  const content = docs
    .filter((d) => {
      const s = slugs.get(d)!
      return s === "index" || !s.endsWith("/index")
    })
    .map((d) => ({
      params: { slug: slugs.get(d)! },
      props: { kind: "content", slug: slugs.get(d)! },
    }))

  // folders: dirname chain of every page, minus root "." and the tags namespace.
  const folders = new Set<string>()
  for (const d of docs) {
    let f = dirname(slugs.get(d)!)
    while (f !== ".") {
      if (f && f !== "tags") folders.add(f)
      f = dirname(f)
    }
  }
  const folderPages = [...folders].map((f) => ({
    params: { slug: `${f}/index` },
    props: { kind: "folder", slug: `${f}/index`, folder: f },
  }))

  // alias redirects (AliasRedirects): each `aliases:` value → a redirect page at
  // slugifyFilePath(alias + ".md") pointing at the owning page. Aliases share the
  // root namespace, so they live in this catch-all. Skip any that collide with a
  // real content/folder page (the real page wins, as ContentPage overwrites
  // AliasRedirects in Quartz's emitter order).
  const toArray = (v: unknown) => (v == null ? [] : Array.isArray(v) ? v : [v])
  const taken = new Set([
    ...content.map((c) => c.params.slug),
    ...folderPages.map((f) => f.params.slug),
  ])
  const aliasSeen = new Set<string>()
  const aliasPages = []
  for (const d of docs) {
    const ogSlug = simplifySlug(slugs.get(d)!)
    // Folder index pages get an implicit alias from their parent directory name
    // (mirrors src/lib/site.ts), so the alias redirect still emits even though
    // index.md no longer spells the directory name out in frontmatter.
    const folderName = folderIndexName(relOf(d))
    const aliases = [...toArray(d.data?.aliases), ...(folderName ? [folderName] : [])]
    for (const alias of aliases) {
      const aSlug = slugifyFilePath((String(alias) + ".md") as FilePath)
      if (taken.has(aSlug) || aliasSeen.has(aSlug)) continue
      aliasSeen.add(aSlug)
      aliasPages.push({
        params: { slug: aSlug },
        props: { kind: "alias", slug: aSlug, redirUrl: resolveRelative(aSlug, ogSlug), ogSlug },
      })
    }
  }

  return [...content, ...folderPages, ...aliasPages]
}

interface Props {
  kind: "content" | "folder" | "alias"
  slug: FullSlug
  folder?: string
  redirUrl?: RelativeURL
  ogSlug?: SimpleSlug
}

// getStaticPaths emits three heterogeneous prop shapes (content/folder/alias);
// Astro infers Astro.props from that union, so we narrow it back to Props here.
const { kind, slug, folder, redirUrl, ogSlug } = Astro.props as Props
const site = kind === "alias" ? null : await loadSite()

// ── alias redirect: a bare HTML refresh page (AliasRedirects). Rendered raw,
// outside PageLayout — the file is exactly this markup.
const aliasHtml =
  kind === "alias"
    ? `<!DOCTYPE html>
<html lang="en-us">
<head>
<title>${ogSlug}</title>
<link rel="canonical" href="${redirUrl}">
<meta name="robots" content="noindex">
<meta charset="utf-8">
<meta http-equiv="refresh" content="0; url=${redirUrl}">
</head>
</html>`
    : ""

// ── content / folder page ────────────────────────────────────────────────────
let title: string = ""
let description = ""
let ContentComp: any = null
let headings: any[] = []
let doc: any = null

if (kind === "content") {
  doc = site!.bySlug.get(slug)!
  const rendered = await render(doc.entry)
  ContentComp = rendered.Content
  headings = rendered.headings
  title = doc.title
} else if (kind === "folder") {
  title = folderTitle(site!, folder!)
  const idx = site!.bySlug.get(`${folder}/index` as FullSlug)
  doc = idx ?? null
  if (idx) {
    const rendered = await render(idx.entry)
    ContentComp = rendered.Content
    headings = rendered.headings
  }
}

const children = kind === "folder" ? listFolderChildren(site!, folder!) : []
const count = children.length
const itemsLabel = count === 1 ? "1 item under this folder" : `${count} items under this folder`

if (kind === "content") {
  description = (doc.entry.body ?? "")
    .replace(/^---[\s\S]*?---/, "")
    .replace(/[#>*_`\[\]\(\)!]/g, "")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 150)
}

const showBreadcrumbs = slug !== "index"
const imgSrc = kind === "content" ? doc?.img : undefined

// Breadcrumb display for the current crumb: content uses its title; a folder uses
// its index title or the dash→space folder segment (NOT the "Folder: x" h1).
const idxDoc = kind === "folder" ? site!.bySlug.get(`${folder}/index` as FullSlug) : null
const crumbTitle =
  kind === "folder"
    ? (idxDoc?.title ?? (folder!.split("/").at(-1) ?? "").replaceAll("-", " "))
    : title
---

{
  kind === "alias" ? (
    <Fragment set:html={aliasHtml} />
  ) : (
    <PageLayout title={title} slug={slug} description={description}>
      <Fragment slot="beforebody">
        {showBreadcrumbs && <Breadcrumbs slug={slug} title={crumbTitle} site={site!} />}
        <ArticleTitle title={title} />
        {doc && <ContentMeta doc={doc} />}
        {kind === "content" && doc && <TagList doc={doc} />}
      </Fragment>

      {imgSrc && <SidebarImage slot="right-top" img={imgSrc} />}
      {headings.length > 0 && <TableOfContents slot="right" headings={headings} />}
      {doc && <Backlinks slot="right" doc={doc} site={site!} />}

      {kind === "content" ? (
        <article class="popover-hint" data-pagefind-body>
          <ContentComp />
        </article>
      ) : (
        <div class="popover-hint">
          <article data-pagefind-body>{ContentComp && <ContentComp />}</article>
          <div class="page-listing">
            <p>{itemsLabel}</p>
            <div>
              <PageList currentSlug={slug} entries={children} />
            </div>
          </div>
        </div>
      )}
    </PageLayout>
  )
}
