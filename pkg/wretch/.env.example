# listener — env overrides. Copy to .env (gitignored) to override the derived
# defaults. Unset vars fall back to defaults derived from the package location
# (pkg/listener/{data,tmp}) — see python/consts.py.

# Where Craig drops session .zip recordings (host-specific).
# Default: ~/drive/Craig
# LISTENER_INCOMING_PATH=/home/jbassin/drive/Craig

# Output + working dirs. At host cutover (Phase 4), point DATA_PATH at the
# existing 27GB store so new sessions land beside historical ones.
# Defaults: pkg/listener/data and pkg/listener/tmp
# LISTENER_DATA_PATH=/ruby/data/experiments/listener_wretch/data
# LISTENER_TMP_PATH=/ruby/data/experiments/listener_wretch/tmp

# Processed-zip state DB (shelve). Default: ${LISTENER_DATA_PATH}/data.pkl
# LISTENER_STATE_FILE=/ruby/data/experiments/listener_wretch/data/data.pkl

# Whisper model / device. Defaults: large-v3 / cpu / int8
# LISTENER_MODEL=large-v3
# LISTENER_DEVICE=cpu
# LISTENER_COMPUTE_TYPE=int8
