# shared-content — content pipeline operational overrides.
# Copy to .env (gitignored) and uncomment to override. All optional;
# defaults live in scripts/config.ts. Run the pipeline from this package
# (`bun run --filter shared-content pipeline`) so Bun loads this .env.

# Ingest source: "remote" (static-audio host — code default) or "local"
# (in-repo listener output). This repo runs local.
INGEST_SOURCE=local

# For INGEST_SOURCE=local: the listener `saved/` dir.
# Default: ../listener/data/saved
#INGEST_SAVED_DIR=

# Port for the local transcript-correction review server. Default: 10116
#REVIEW_PORT=10116

# Path to caster-site episodes.json for podcast deep-links.
# Default: ../caster/site/dist/episodes.json
#PODCAST_EPISODES_PATH=
