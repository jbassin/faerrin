# @faerrin/content — content pipeline operational overrides.
# Copy to .env (gitignored) and uncomment to override. All optional;
# defaults live in scripts/config.ts. Run the pipeline from this package
# (`bun run --filter @faerrin/content pipeline`) so Bun loads this .env.

# Ingest source: "remote" (static-audio host — code default) or "local"
# (in-repo wretch output). This repo runs local.
INGEST_SOURCE=local

# For INGEST_SOURCE=local: the wretch `saved/` dir.
# Default: ../wretch/data/saved
#INGEST_SAVED_DIR=

# Port for the local transcript-correction review server. Default: 10116
#REVIEW_PORT=10116

# Path to face episodes.json for podcast deep-links.
# Default: ../face/dist/episodes.json
#PODCAST_EPISODES_PATH=

# --- typo surfacer, Phase 2 (`surface judge`) ---
# Required only for the LLM judge. Read from this package's cwd by Bun.
#ANTHROPIC_API_KEY=
# Optional model overrides (defaults: Haiku 4.5 judge, Sonnet 4.6 escalation).
#SURFACE_MODEL_JUDGE=claude-haiku-4-5-20251001
#SURFACE_MODEL_ESCALATE=claude-sonnet-4-6
