# Port the Bun server listens on (HTTP ingest + SSE + static overlay).
PORT=8787

# Shared secret. @faerrin/mouth must send this as the `X-Eerie-Token` header on
# every roll POST; the ingest endpoint 401s without it. Generate a long random
# value and keep it out of git (this .env is gitignored).
EERIE_TOKEN=
