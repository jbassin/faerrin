{
  "name": "@faerrin/eerie",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Live dice-roll OBS overlay — ingests @faerrin/mouth's roll broadcast, fans it out over SSE, renders an animated ticker OBS captures as a Browser Source.",
  "scripts": {
    "dev": "vite",
    "dev:server": "bun run --hot server.ts",
