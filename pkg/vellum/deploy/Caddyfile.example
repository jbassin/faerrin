# vellum.iridi.cc — APPEND this block to the gitignored root `sites.caddyfile`
# on the host (that file holds a Cloudflare DNS token and is not version-
# controlled; this is the documented host-update step, NFR-8).
#
# Topology: Caddy serves the static editor SPA from dist/, and reverse-proxies
# the render API to the warm Bun + Playwright sidecar (see
# vellum-render.service.example). Because the browser hits /render on the SAME
# origin, no CORS is needed and the editor defaults to a same-origin render URL
# (leave VITE_VELLUM_RENDER_URL UNSET for the production build — see
# .env.example).

vellum.iridi.cc {
	encode zstd gzip

	# Render API → warm render service sidecar (localhost only).
	@api path /render /health
	handle @api {
		reverse_proxy 127.0.0.1:5252
	}

	# Static editor SPA (single route → index.html fallback).
	handle {
		root * /ruby/data/experiments/faerrin/pkg/vellum/dist
		try_files {path} /index.html
		file_server
	}
}
