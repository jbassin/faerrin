# Editor → render-service URL.
#
# Local dev: point at the sidecar you start with `bun run render:server`.
VITE_VELLUM_RENDER_URL=http://localhost:5252
#
# Production: leave EMPTY so the editor posts same-origin (/render), which Caddy
# reverse-proxies to the sidecar (see deploy/Caddyfile.example). Build with:
#   VITE_VELLUM_RENDER_URL= bun run build
