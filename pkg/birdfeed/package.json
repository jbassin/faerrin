{
  "name": "@faerrin/birdfeed",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Elgato Stream Deck plugin that remote-controls the @faerrin/lark Discord music bot (lark → collection → tag navigation, live now-playing) over lark's HTTP REST API.",
  "prettier": "@elgato/prettier-config",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "bundle": "rollup -c",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.faerrin.birdfeed\"",
    "package": "rollup -c && streamdeck pack com.faerrin.birdfeed.sdPlugin --output dist --force --no-update-check --ignore-validation"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@tsconfig/node20": "^20.1.4",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.13.0",
    "rollup": "^4.32.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
