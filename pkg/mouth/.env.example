# speaks — environment configuration. Copy to `.env` (gitignored) for local runs,
# or supply these via systemd `EnvironmentFile=` in production (see deploy/).
# Bun does NOT load this; the Rust binary reads the process environment directly
# (optionally seeded from a local .env via dotenvy when present).

# --- secrets (NEVER commit real values) ---
# Discord bot token.
DISCORD_TOKEN=

# Dice-feed Discord webhook. ⚠️ The previously hardcoded token was leaked in git
# history and MUST be rotated in Discord — paste the NEW webhook URL here.
DICE_FEED_URL=

# --- datastore (SQLite; the bot self-creates the schema on first run) ---
# Triple slash = absolute path. The file holds only dice history + macros.
DATABASE_URL=sqlite:///home/you/.local/share/faerrin/speaks.db

# --- service endpoints (env-driven; were hardcoded before Phase 1) ---
# Roll-broadcast websocket feed (kept feature).
FEED_WS_URL=https://feed-ws.iridi.cc/broadcast/roll
# Embedding service (whole subsystem removed in Phase 2).
EMBED_URL=https://embed.iridi.cc/embeddings
# Chart-rendering service base URL (no trailing slash).
CHART_BASE_URL=https://chart.iridi.cc

# --- http control plane ---
# axum bind address. Internal-only by default; only widen behind a trusted proxy.
MOUTH_BIND_ADDR=127.0.0.1:10203

# --- identity ---
# Path to the bot identity file (snowflake -> player). Defaults to players.toml
# relative to cwd (the systemd unit sets WorkingDirectory to this package).
MOUTH_PLAYERS_PATH=players.toml

# --- logging ---
RUST_LOG=info
