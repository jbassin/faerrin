# caster — audio/podcast (TTS) pipeline.
# Copy to .env (gitignored) and fill in. Bun auto-loads .env from this dir,
# so run caster from pkg/caster.

# Required for the distillation/script step (LLM via @faerrin/llm).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — only needed for `--provider=elevenlabs`. The `--provider=edge`
# (free) and `--provider=mock` (offline) TTS paths need no key.
ELEVENLABS_API_KEY=

# Note: TTS provider is selected with the `--provider=` CLI flag, not an env var.
