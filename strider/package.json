{
  "name": "strider",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && bun run scripts/build-og-image.ts",
    "build:og": "bun run scripts/build-og-image.ts",
    "lint": "eslint .",
    "typecheck": "bun run scripts/generate-routes.ts && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --pass-with-no-tests",
    "format": "prettier --write .",
    "editor:server": "bun run --hot scripts/editor-server.ts",
    "generate:content": "bun run scripts/build-content.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@tanstack/react-router": "^1.170.7",
    "@tanstack/react-start": "^1.168.10",
    "pixi-filters": "^6",
    "pixi.js": "^8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "serve": "^14.2.6",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^8",
    "vitest": "^4.1.7"
  }
}
