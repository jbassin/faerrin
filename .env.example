# Faerrin monorepo — environment variables.
# Copy to .env (gitignored) and fill in. Bun auto-loads .env from the cwd of the
# launched process; run apps from their own dir or pass --env-file as needed.

# ── Shared ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=        # required by caster + heartwood

# ── caster ───────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=       # optional; only for `--provider=elevenlabs` (edge/mock need no key)

# ── heartwood ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=             # classic PAT `repo` scope, or fine-grained Contents + Pull requests RW
GITHUB_REPO=              # owner/name of the repo hosting content/
GITHUB_API_URL=           # optional; defaults to https://api.github.com (set for Enterprise)
# Optional model overrides (defaults live in heartwood/src/config.ts):
MODEL_SEGMENT=
MODEL_EXTRACT=
MODEL_FILTER=
MODEL_RESOLVE=
MODEL_MATCH=
MODEL_PROPOSE=
MODEL_VERIFY=

# ── quartz (non-secret operational overrides) ────────────────────────────────
REVIEW_PORT=              # default 10116
PODCAST_EPISODES_PATH=    # default points at the caster episodes.json (see migration notes)
