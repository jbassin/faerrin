---
// Ports TableOfContents.tsx (modern layout). Headings come from Astro's render()
// (github-slugger anchors, same as Quartz). Depth classes are normalized to the
// shallowest heading, matching the Quartz TOC transformer (depth - lowestDepth).
// Quartz caps at maxDepth 3 and only renders when toc.length > minEntries (1) —
// i.e. STRICTLY MORE THAN ONE qualifying heading. (No current page has ≥2, so
// like the live site this renders nothing; it's correct for future multi-heading
// pages.) Collapse + scroll-highlight are Phase 3.
interface Heading {
  depth: number
  slug: string
  text: string
}
interface Props {
  headings: Heading[]
}
const { headings } = Astro.props
const entries = headings.filter((h) => h.depth <= 3)
const lowest = entries.length ? Math.min(...entries.map((h) => h.depth)) : 0
---

{
  entries.length > 1 && (
    <div class="toc">
      <button type="button" class="toc-header" aria-expanded="true">
        <h3>Table of Contents</h3>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="fold"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>
      <ul class="toc-content">
        {entries.map((h) => (
          <li class={`depth-${h.depth - lowest}`}>
            <a href={`#${h.slug}`} data-for={h.slug}>
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )
}
