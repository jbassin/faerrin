# Dependencies — hoisted to the workspace root under bun workspaces.
# (Per-app .gitignore files remain authoritative for app-specific outputs:
#  e.g. aether public/.astro, strider dist/src/generated/routeTree.gen.ts,
#  heartwood state/ allow-lists. Do NOT consolidate those up here.)
node_modules/

# Environment / secrets — NEVER commit real values. Only .env.example is tracked.
.env
.env.*
!.env.example
sites.caddyfile

# Build caches
*.tsbuildinfo
.DS_Store
